// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// --- StockSignal Phase 1: data layer ---

// A local snapshot of one sellable product variant, plus the per-product
// reorder settings the merchant controls. Refreshed by the catalog backfill.
// Keyed by the Shopify variant GID so upserts are idempotent.
model Variant {
  id                String   @id // Shopify ProductVariant GID
  shop              String
  productId         String   // Shopify Product GID
  productTitle      String
  variantTitle      String?
  sku               String?
  price             Float    @default(0) // unit price; used for revenue velocity (Surface 2)
  inventoryQuantity Int      @default(0) // current on-hand at the single location
  productStatus     String   @default("ACTIVE")
  productCreatedAt  DateTime // for the new-product guard (>= 30-60 days active)

  // Per-product reorder setting (tunable; default per CLAUDE.md spec). Lead
  // time genuinely varies by supplier/product, so it lives per variant. The
  // safety buffer + coverage target are store-wide policy (see StoreSettings).
  leadTimeDays Int @default(7) // days from reorder to restock

  // Throttle for urgent reorder alerts: when we last emailed about this variant
  // crossing into "reorder now". Not refreshed by catalog sync.
  lastReorderAlertAt DateTime?

  updatedAt DateTime @updatedAt

  @@index([shop])
}

// One row per order line item. Keyed by the Shopify line-item GID so a
// re-delivered orders/create webhook (or an overlapping backfill) upserts
// instead of double-counting. Velocity = SUM(quantity) GROUP BY variant
// over a trailing window of processedAt.
model OrderLine {
  id          String   @id // Shopify LineItem GID
  shop        String
  orderId     String   // Shopify Order GID
  variantId   String?  // null if the variant was since deleted; skipped in velocity
  quantity    Int
  processedAt DateTime // order processed date (NOT createdAt — seeds are backdated)

  @@index([shop, variantId, processedAt])
  @@index([orderId])
}

// Per-shop sync bookkeeping.
model ShopSync {
  shop           String    @id
  lastBackfillAt DateTime?
  updatedAt      DateTime  @updatedAt
}

// Per-shop tunable settings. The velocity window is the trailing number of days
// the engine averages sales over (configurable to 30/60/90 per the spec).
// Future phases add re-evaluate bottom-slice %, email prefs, etc. here.
model StoreSettings {
  shop               String   @id
  velocityWindowDays Int      @default(30) // trailing window the engine averages over
  safetyBufferDays   Int      @default(3) // extra days of cushion before flagging reorder
  reorderCoverageDays Int     @default(30) // suggested order = enough to cover this many days
  reevaluateBottomPercent Int @default(20) // flag the slowest N% of the catalog by revenue velocity
  minActiveDays      Int      @default(30) // new-product guard: skip items active fewer than this

  // Phase 5 notification settings.
  digestEmail         String? // recipient for digest + alerts (null = not configured)
  digestEnabled       Boolean  @default(true) // send the weekly digest
  urgentAlertsEnabled Boolean  @default(true) // send urgent "reorder now" alerts

  updatedAt          DateTime @updatedAt
}
